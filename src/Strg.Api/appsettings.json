{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "RabbitMQ": {
    "Host": "localhost",
    "VirtualHost": "/"
  },
  "MassTransit": {
    "OutboxPollingIntervalSeconds": 5
  },
  "Observability": {
    "OtlpEndpoint": "http://localhost:4317"
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "RateLimiting": {
    "Auth": { "PermitLimit": 10, "WindowSeconds": 60, "QueueLimit": 0 },
    "Global": { "PermitLimit": 1000, "WindowSeconds": 60, "QueueLimit": 0 }
  }
}
